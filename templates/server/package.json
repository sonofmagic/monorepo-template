{
  "name": "@icebreakers/server",
  "type": "module",
  "version": "0.0.0",
  "description": "tsup(esbuild) build package template",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "templates/server"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/trpc-router.ts",
    "./config": "./src/config.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsup",
    "build:watch": "tsup --watch --sourcemap",
    "node:build:watch": "pnpm build:watch",
    "node:build": "pnpm build",
    "node:dev": "tsx watch src/node-entry.ts",
    "node:start": "node dist/node-entry.js",
    "test": "vitest run",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "pnpm cf-typegen",
    "typecheck": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.0",
    "consola": "^3.4.2",
    "hono": "^4.12.14",
    "wrangler": "^4.84.0",
    "zod": "^4.3.6"
  }
}
