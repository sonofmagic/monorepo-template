{
  "name": "monorepo-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "author": "ice breaker <hi@sonofmagic.top>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "tooling:build": "turbo run build --filter=@icebreakers/monorepo --filter=repoctl",
    "dev": "turbo run dev --parallel",
    "test": "vitest run",
    "test:dev": "vitest",
    "lint": "pnpm run tooling:build && turbo run lint",
    "tsd": "turbo run tsd",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:fix": "pnpm audit --fix",
    "typecheck": "turbo run typecheck",
    "format": "eslint . --fix",
    "validate": "pnpm run build && pnpm run lint && pnpm run typecheck && pnpm run tsd && pnpm run test",
    "release": "changeset",
    "publish-packages": "repo release stable",
    "release:pre": "repo release pre publish",
    "------": "--------------",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "commit",
    "commitlint": "commitlint --edit",
    "-------": "---------------",
    "repo:init": "repo init",
    "repo:new": "repo new",
    "repo:check": "repo check",
    "repo:doctor": "repo doctor",
    "------simple": "--------------",
    "pr:alpha": "repo release pre enter alpha",
    "pr:beta": "repo release pre enter beta",
    "pr:rc": "repo release pre enter rc",
    "pr:next": "repo release pre enter next",
    "pr:exit": "repo release pre exit",
    "--------": "----------------"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/monorepo": "workspace:*",
    "@types/node": "^25.9.2",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "~4.1.8",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "defu": "^6.1.7",
    "es-toolkit": "^1.47.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "repoctl": "workspace:*",
    "stylelint": "^17.13.0",
    "tailwindcss": "^4.3.0",
    "tsd": "^0.33.0",
    "tsdown": "0.22.2",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.17",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "~4.1.8",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
