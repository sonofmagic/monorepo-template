{
  "name": "monorepo-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "author": "ice breaker <hi@sonofmagic.top>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "tooling:build": "turbo run build --filter=@icebreakers/monorepo --filter=repoctl",
    "dev": "turbo run dev --parallel",
    "test": "vitest run",
    "test:dev": "vitest",
    "lint": "turbo run lint",
    "tsd": "turbo run tsd",
    "audit": "pnpm audit --audit-level=moderate",
    "audit:fix": "pnpm audit --fix",
    "typecheck": "turbo run typecheck",
    "format": "eslint . --fix",
    "validate": "pnpm run build && pnpm run lint && pnpm run typecheck && pnpm run tsd && pnpm run test",
    "release": "changeset",
    "publish-packages": "turbo run build lint test && changeset version && changeset publish",
    "------": "--------------",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "commit",
    "commitlint": "commitlint --edit",
    "-------": "---------------",
    "setup": "repoctl setup",
    "new": "repoctl new",
    "check": "repoctl check",
    "sync": "repoctl sync",
    "clean:repo": "repoctl clean",
    "mirror": "repoctl mirror",
    "------simple": "--------------",
    "pr:alpha": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "--------": "----------------",
    "script:init": "repoctl init",
    "script:sync": "repoctl sync",
    "script:clean": "repoctl clean",
    "script:mirror": "repoctl mirror"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/commitlint-config": "^2.0.0",
    "@icebreakers/eslint-config": "^4.0.8",
    "@icebreakers/monorepo": "workspace:*",
    "@icebreakers/stylelint-config": "^3.0.5",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "~4.1.5",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "defu": "^6.1.7",
    "es-toolkit": "^1.46.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.0",
    "repoctl": "workspace:*",
    "stylelint": "^17.9.0",
    "tailwindcss": "^4.2.4",
    "tsd": "^0.33.0",
    "tsdown": "0.21.10",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "~4.1.5",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
