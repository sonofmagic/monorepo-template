{
  "name": "create-repoctl",
  "type": "module",
  "version": "0.0.8",
  "description": "Bootstrap repoctl monorepo projects via npm create, yarn create, or pnpm create",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/create-repoctl"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "repoctl",
    "monorepo",
    "create-app",
    "template",
    "scaffold"
  ],
  "sideEffects": false,
  "bin": {
    "create-repoctl": "bin/create-repoctl.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "typecheck": "pnpm --filter create-icebreaker build && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "create-icebreaker": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
