{
  "name": "@icebreakers/monorepo",
  "type": "module",
  "version": "3.2.18",
  "description": "The icebreaker's monorepo manager",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "homepage": "https://monorepo.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/monorepo"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "monorepo",
    "icebreaker"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./tooling": {
      "types": "./dist/tooling-entry.d.mts",
      "default": "./dist/tooling-entry.mjs"
    },
    "./tsconfig": "./tsconfig.base.json",
    "./tsconfig.json": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "rc": "bin/rc.js",
    "repo": "bin/repo.js",
    "repoctl": "bin/repoctl.js",
    "monorepo": "bin/monorepo.js",
    "mo": "bin/mo.js"
  },
  "files": [
    "bin",
    "dist",
    "resources",
    "tsconfig.base.json"
  ],
  "engines": {
    "node": ">=23.5.0 || ^22.13.0 || ^21.7.0 || ^20.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "tsd": "pnpm build && tsd --files test-d/**/*.test-d.ts",
    "release": "pnpm publish",
    "lint": "pnpm build && pnpm --filter repoctl build && eslint .",
    "lint:fix": "pnpm build && pnpm --filter repoctl build && eslint . --fix"
  },
  "dependencies": {
    "@icebreakers/commitlint-config": "^1.2.13",
    "@icebreakers/eslint-config": "^2.0.2",
    "@icebreakers/monorepo-templates": "workspace:*",
    "@icebreakers/stylelint-config": "^2.1.1",
    "@pnpm/find-workspace-dir": "^1000.1.4",
    "@pnpm/logger": "^1001.0.1",
    "@pnpm/types": "^1001.3.0",
    "@pnpm/worker": "^1000.6.6",
    "@pnpm/workspace.find-packages": "^1000.0.64",
    "@pnpm/workspace.read-manifest": "^1000.3.0",
    "c12": "^3.3.3",
    "comment-json": "^4.6.2",
    "consola": "^3.4.2",
    "git-url-parse": "^16.1.0",
    "klaw": "^4.1.0",
    "lint-staged": "^16.4.0",
    "p-queue": "^9.1.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "simple-git": "^3.33.0",
    "vitest": "~4.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/klaw": "^3.0.7",
    "@types/micromatch": "^4.0.10",
    "fdir": "^6.5.0",
    "micromatch": "^4.0.8"
  }
}
