{
  "name": "@icebreakers/monorepo",
  "type": "module",
  "version": "4.0.13",
  "description": "Core engine behind the repoctl monorepo CLI",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "homepage": "https://repo.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/monorepo"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "monorepo",
    "repoctl",
    "tooling",
    "icebreaker"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./tooling": {
      "types": "./dist/tooling-entry.d.mts",
      "default": "./dist/tooling-entry.mjs"
    },
    "./tsconfig": "./tsconfig.base.json",
    "./tsconfig.json": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "repo": "bin/repo.js",
    "repoctl": "bin/repoctl.js"
  },
  "files": [
    "bin",
    "dist",
    "resources",
    "tsconfig.base.json"
  ],
  "engines": {
    "node": ">=23.5.0 || ^22.13.0 || ^21.7.0 || ^20.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "pnpm --filter @icebreakers/monorepo-templates build && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "tsd": "pnpm build && tsd --files test-d/**/*.test-d.ts",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "@commitlint/cli": "^21.0.2",
    "eslint": "^9.0.0 || ^10.0.0",
    "stylelint": "^17.13.0",
    "typescript": "^5.0.0 || ^6.0.0",
    "vitest": "^4.1.8"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "dependencies": {
    "@icebreakers/commitlint-config": "^3.0.1",
    "@icebreakers/eslint-config": "^5.0.4",
    "@icebreakers/monorepo-templates": "workspace:*",
    "@icebreakers/stylelint-config": "^4.0.2",
    "@pnpm/find-workspace-dir": "^1000.1.5",
    "@pnpm/logger": "^1100.0.0",
    "@pnpm/types": "^1101.3.0",
    "@pnpm/worker": "^1100.1.9",
    "@pnpm/workspace.find-packages": "^1000.0.65",
    "@pnpm/workspace.read-manifest": "^1000.3.1",
    "c12": "^3.3.4",
    "commander": "^15.0.0",
    "comment-json": "^5.0.0",
    "consola": "^3.4.2",
    "git-url-parse": "^16.1.0",
    "klaw": "^4.1.0",
    "lint-staged": "^17.0.7",
    "p-queue": "^9.3.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.8.4",
    "simple-git": "^3.36.0",
    "vitest": "~4.1.8",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/klaw": "^3.0.7",
    "@types/micromatch": "^4.0.10",
    "fdir": "^6.5.0",
    "micromatch": "^4.0.8"
  }
}
