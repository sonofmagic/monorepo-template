{
  "name": "@icebreakers/monorepo-templates",
  "type": "module",
  "version": "0.1.16",
  "description": "Template assets for icebreaker monorepo scaffolding",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/monorepo-templates"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "monorepo",
    "template",
    "scaffold"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "assets",
    "assets-data.mjs",
    "dist",
    "template-data.mjs",
    "templates"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "tsd": "pnpm build && tsd --files test-d/**/*.test-d.ts",
    "sync:assets": "pnpm run build && node scripts/sync-assets.mjs",
    "prepack": "pnpm run build && node scripts/sync-assets.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.1.4",
    "@inquirer/input": "^5.0.12",
    "@inquirer/select": "^5.1.4",
    "commander": "^14.0.3",
    "nanoexec": "^1.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
