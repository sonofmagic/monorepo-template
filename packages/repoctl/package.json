{
  "name": "repoctl",
  "type": "module",
  "version": "4.0.13",
  "description": "Default task-first CLI for pnpm and Turbo monorepo setup and maintenance",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "homepage": "https://repo.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/repoctl"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "repoctl",
    "repo",
    "cli",
    "toolchain",
    "pnpm",
    "turbo",
    "monorepo"
  ],
  "sideEffects": false,
  "tsd": {
    "compilerOptions": {
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "skipLibCheck": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./tooling": {
      "types": "./dist/tooling-entry.d.mts",
      "default": "./dist/tooling-entry.mjs"
    },
    "./tsconfig": "./tsconfig.json",
    "./tsconfig.json": "./tsconfig.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "repo": "bin/repo.js",
    "repoctl": "bin/repoctl.js"
  },
  "files": [
    "bin",
    "dist",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=23.5.0 || ^22.13.0 || ^21.7.0 || ^20.12.0"
  },
  "scripts": {
    "dev": "tsdown --tsconfig tsconfig.src.json --watch --sourcemap",
    "build": "tsdown --tsconfig tsconfig.src.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm --filter @icebreakers/monorepo build && node ../../node_modules/typescript/bin/tsc -p tsconfig.src.json",
    "tsd": "pnpm --filter @icebreakers/monorepo build && pnpm build && tsd --files test-d/**/*.test-d.ts",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "@commitlint/cli": "^21.1.0",
    "eslint": "^9.0.0 || ^10.0.0",
    "stylelint": "^17.14.0",
    "typescript": "^5.0.0 || ^6.0.0",
    "vitest": "^4.1.9"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "dependencies": {
    "@icebreakers/monorepo": "workspace:*"
  }
}
