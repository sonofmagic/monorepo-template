{
  "name": "repoctl",
  "type": "module",
  "version": "4.0.0",
  "description": "Default task-first CLI for pnpm and Turbo monorepo setup and maintenance",
  "author": "ice breaker <hi@sonofmagic.top>",
  "license": "MIT",
  "homepage": "https://monorepo.icebreaker.top",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git",
    "directory": "packages/repoctl"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "keywords": [
    "repoctl",
    "repo",
    "cli",
    "toolchain",
    "pnpm",
    "turbo",
    "monorepo"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./tooling": {
      "types": "./dist/tooling-entry.d.mts",
      "default": "./dist/tooling-entry.mjs"
    },
    "./tsconfig": "./tsconfig.base.json",
    "./tsconfig.json": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "rc": "bin/rc.js",
    "repo": "bin/repo.js",
    "repoctl": "bin/repoctl.js",
    "monorepo": "bin/monorepo.js",
    "mo": "bin/mo.js"
  },
  "files": [
    "bin",
    "dist",
    "tsconfig.base.json"
  ],
  "engines": {
    "node": ">=23.5.0 || ^22.13.0 || ^21.7.0 || ^20.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm --filter @icebreakers/monorepo build && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "tsd": "pnpm --filter @icebreakers/monorepo build && pnpm build && tsd --files test-d/**/*.test-d.ts",
    "release": "pnpm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@icebreakers/monorepo": "workspace:*"
  }
}
